  m_Script: {fileID: 11500000, guid: 9ecf51cdea88d44458a0af657031e21b, type: 3}
  m_Name: vaguear
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speakerName: 
    text: " \u201CPrefiero tomarlo con calma\u201D"
    portrait: {fileID: 0}
  - speakerName: EbonyDarkn3ss
    text: " \u201CComo deber\xEDa ser\u201D"
    portrait: {fileID: -7524853238701397633, guid: af605bb8ba0924743867c8ebf5c80345, type: 3}
  - speakerName: EbonyDarkn3ss
    text: "\u201CTotal, hoy en dia no cunde darse tanta ca\xF1a con todo.\u201D\r\n"
    portrait: {fileID: -7524853238701397633, guid: af605bb8ba0924743867c8ebf5c80345, type: 3}
  - speakerName: Dario_OfDuty23
    text: " \u201CEso lo dir\xE1s t\xFA\u201D\r\n"
    portrait: {fileID: 4446270891161247759, guid: 748bef39c5d1e5b42b9ebdd5bbf7f849, type: 3}
  - speakerName: EbonyDarkn3ss
    text: "\u201C\xBFTe has visto? vives en un zulo\u201D"
    portrait: {fileID: 3964466543063010452, guid: b8d978cc7267f574e8faf94b712bce6e, type: 3}
  - speakerName: Dario_OfDuty23
    text: " \u201CPero independizado, a diferencia de muchos\u201D\r\n"
    portrait: {fileID: 4446270891161247759, guid: 748bef39c5d1e5b42b9ebdd5bbf7f849, type: 3}
  - speakerName: Dario_OfDuty23
    text: "\u201CBueno, \xA1\xA1me voy a comer!!\u201D"
    portrait: {fileID: 6698486588563270900, guid: 7b3d2586cb45bfe4e9fab0e19a0593fb, type: 3}
  - speakerName: 
    text: "\u201CAdi\xF3s.\u201D"
    portrait: {fileID: 0}
  - speakerName: EbonyDarkn3ss
    text: " \u201C\xBFQu\xE9 te apuestas a que come pollo hervido con arroz blanco?\u201D"
    portrait: {fileID: -7524853238701397633, guid: af605bb8ba0924743867c8ebf5c80345, type: 3}
  - speakerName: 
    text: "\u201CPor favor no\u201D"
    portrait: {fileID: 0}
  - speakerName: EbonyDarkn3ss
    text: " \u201CJa, ja, ja, ja, me voy a comer tambi\xE9n, te veo en un rato\u201D"
    portrait: {fileID: -7524853238701397633, guid: af605bb8ba0924743867c8ebf5c80345, type: 3}
  - speakerName: EbonyDarkn3ss
    text: "\xBFTe unes a ver anime despu\xE9s?\u201D \r\n"
    portrait: {fileID: -7524853238701397633, guid: af605bb8ba0924743867c8ebf5c80345, type: 3}
  choices:
  - choiceText: No
    nextDialogue: {fileID: 11400000, guid: 07d47e0e999f4f2459c12b0f7da82ef6, type: 2}
  - choiceText: Si
    nextDialogue: {fileID: 11400000, guid: 675a928ff18c51b42bc4bedc9e596ec3, type: 2}
