  m_Script: {fileID: 11500000, guid: 9ecf51cdea88d44458a0af657031e21b, type: 3}
  m_Name: PlanDeCasa
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - speakerName: 
    text: "\u201CHmmm, en realidad mantita y una serie estar\xEDa bien\u201D"
    portrait: {fileID: 0}
  - speakerName: MakotoUchiha69
    text: "\u201C\xBF\xBF\xBF\xBF\xBF\xBFVessss??????\u201D \r\n"
    portrait: {fileID: -5538810942529525774, guid: a33738f2fe3bd9f41bb3279fa1a5f8a6, type: 3}
  - speakerName: EbonyDarkn3ss
    text: "\u201CBueno, me imagino que estar\xE1s cansado de todo ahora\u2026\u201D"
    portrait: {fileID: -6173394557037535750, guid: afe1f47c1d14b3a4dac12880c450bf80, type: 3}
  - speakerName: MakotoUchiha69
    text: "\u201CNo hay nada como ver monas chinas, \xBF\xBFa que si, a que si??\u201D"
    portrait: {fileID: -5538810942529525774, guid: a33738f2fe3bd9f41bb3279fa1a5f8a6, type: 3}
  - speakerName: EbonyDarkn3ss
    text: "\u201COk, gooner\u2026\u201D"
    portrait: {fileID: -6173394557037535750, guid: afe1f47c1d14b3a4dac12880c450bf80, type: 3}
  - speakerName: MakotoUchiha69
    text: " \u201CSi\u201D"
    portrait: {fileID: -8576269753853732610, guid: 49f8ef726cb140943aa2ed0a29db090a, type: 3}
  - speakerName: MakotoUchiha69
    text: "\u201C\xBFQu\xE9 pasa?\u201D\r\n"
    portrait: {fileID: -8576269753853732610, guid: 49f8ef726cb140943aa2ed0a29db090a, type: 3}
  - speakerName: 
    text: " \u201CTe ir\xE9 diciendo, voy a estar tirando CVs pero tal y como est\xE1
      el tema dudo tener trabajo\u201D\r\n"
    portrait: {fileID: 0}
  - speakerName: EbonyDarkn3ss
    text: " \u201C\xBFNo te vas a tomar un tiempo para ti entonces?\u201D\r\n"
    portrait: {fileID: 3026516191082340819, guid: 8c6361e39224b04498bc68701dc0e314, type: 3}
  - speakerName: 
    text: " \u201CMe gustar\xEDa, pero  no creo que me pueda permitir ser un nini
      demasiado tiempo\u201D"
    portrait: {fileID: 0}
  - speakerName: MakotoUchiha69
    text: "\u201CLo que t\xFA digas, me voy a dormir -3-\u201D"
    portrait: {fileID: -8601036296743456369, guid: be0c7c0465317b945b3e951ae8f06383, type: 3}
  - speakerName: 
    text: "\u201C\xBF\xBFAhora?? \xA1Pero si es por la ma\xF1ana!\u201D\r\n"
    portrait: {fileID: 0}
  - speakerName: EbonyDarkn3ss
    text: "\u201C\xA1Hmp! lo dices como si no hubieras estado haciendo los mismo
      durante a\xF1os\u201D\r\n"
    portrait: {fileID: -6173394557037535750, guid: afe1f47c1d14b3a4dac12880c450bf80, type: 3}
  - speakerName: EbonyDarkn3ss
    text: "\u201CBueno, como todos nosotros supongo\u201D\r\n"
    portrait: {fileID: -6173394557037535750, guid: afe1f47c1d14b3a4dac12880c450bf80, type: 3}
  - speakerName: EbonyDarkn3ss
    text: "\u201CBuenas nochees\u201D"
    portrait: {fileID: 3964466543063010452, guid: b8d978cc7267f574e8faf94b712bce6e, type: 3}
  - speakerName: MakotoUchiha69
    text: " \u201CNight nighttttt UwU\u201D"
    portrait: {fileID: -5538810942529525774, guid: a33738f2fe3bd9f41bb3279fa1a5f8a6, type: 3}
  - speakerName: 
    text: "\xBFQu\xE9 deber\xEDa hacer ahora? Supongo que no tengo nada m\xE1s que
      hacer que buscar algunas ofertas de trabajo."
    portrait: {fileID: 0}
  choices: []
